import std.io.*;

libc :: import libc.*;
u8 :: unsigned char;
 
const file_name = "Hello World";

// Changes from C 
// module system 
// const can infer type and can be a real constant
// macro system that can do the normal preprocessor shit
// defer 
// methods through impl 
// interfaces and traits
// named function args, and default arguments
// function overloading 
// ffi
// keep the goto and the long jump
// you will be able to do more shit on the global scope
// lambdas and local function declarations
// block expr {} like gnu stmt expr ({})

u32! divide(u32 a, u32 b) {
    if(b == 0) return Error("divide by zero"); 
    return a / b;
}


void main(string[] args) {
    const string s= "Hello World!";
    char s2[] = s[0..5];
    char* const s3 = s[0..5];
    
    let res = divide(500,25)!; 

    libc.printf("%d\n", res);   
    println("{} , {}",s, s2);
}


